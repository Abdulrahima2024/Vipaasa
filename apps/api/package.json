    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "prisma": "^5.18.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
