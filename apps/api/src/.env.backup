# =============================================================================
# VIPAASA ORGANICS — BACKEND API
# File: apps/api/.env.example
# Naprocs Technologies
# -----------------------------------------------------------------------------
# INSTRUCTIONS:
#   1. Copy this file → apps/api/.env
#   2. Fill every REQUIRED value before running the server
#   3. NEVER commit .env to git — it is in .gitignore
#   4. In PRODUCTION — all values come from AWS Secrets Manager via IAM role
#      No .env file exists on the production EC2 instance
# =============================================================================


# =============================================================================
# SERVER
# =============================================================================

NODE_ENV=development
# OPTIONS: development | staging | production
# REQUIRED

PORT=4000
# Port the Express server listens on
# OPTIONAL — default: 4000

API_BASE_URL=http://localhost:4000
# Full base URL of this API server (no trailing slash)
# REQUIRED
# PROD: https://api.vipaasaorganics.com

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Comma-separated list of allowed CORS origins
# REQUIRED
# PROD: https://vipaasaorganics.com,https://admin.vipaasaorganics.com


# =============================================================================
# DATABASE — PostgreSQL via PgBouncer
# =============================================================================

DATABASE_URL=postgresql://neondb_owner:npg_uGEmTpzij82H@ep-dark-leaf-af2xu3is.c-2.us-west-2.aws.neon.tech/neondb?sslmode=require
# Primary database connection — points to PgBouncer port in staging/prod
# REQUIRED
# DEV:     postgresql://vipaasa_user:password@localhost:5432/vipaasa_dev
# STAGING: postgresql://vipaasa_user:password@pgbouncer-staging:6432/vipaasa_staging
# PROD:    postgresql://vipaasa_user:password@pgbouncer-prod:6432/vipaasa_prod

DATABASE_URL_READ=postgresql://vipaasa_user:your_password@localhost:5432/vipaasa_dev?schema=public
# Read replica connection — used exclusively for reports and analytics queries
# REQUIRED in staging/prod — use same as DATABASE_URL in development only
# PROD: postgresql://vipaasa_user:password@rds-replica.ap-south-1.rds.amazonaws.com:5432/vipaasa_prod

DATABASE_POOL_SIZE=20
# PgBouncer max connection pool size
# OPTIONAL — default: 20
# Recommended: 20 for t3.medium EC2 + RDS t3.small


# =============================================================================
# REDIS — Upstash (serverless, Mumbai PoP)
# =============================================================================

REDIS_URL=rediss://default:your_upstash_token@your-instance.upstash.io:6379
# Full Redis connection URL — must use rediss:// (with double s) for TLS
# REQUIRED
# Get from: Upstash Console → Database → Connect → Node.js (ioredis)

REDIS_TOKEN=your_upstash_rest_token
# Upstash REST API token — used by HTTP-based Redis client
# REQUIRED
# Get from: Upstash Console → Database → REST API → Token

REDIS_TTL_PRODUCT_CACHE=300
# Product catalogue cache TTL in seconds
# OPTIONAL — default: 300 (5 minutes)

REDIS_TTL_OTP=600
# OTP storage TTL in seconds
# OPTIONAL — default: 600 (10 minutes)

REDIS_TTL_CART=604800
# Guest cart TTL in seconds
# OPTIONAL — default: 604800 (7 days)

REDIS_TTL_CART_AUTH=2592000
# Authenticated user cart TTL in seconds
# OPTIONAL — default: 2592000 (30 days)

REDIS_TTL_INVENTORY_RESERVATION=900
# Inventory reservation lock TTL in seconds
# OPTIONAL — default: 900 (15 minutes)

REDIS_TTL_WEBHOOK_IDEMPOTENCY=86400
# Razorpay webhook idempotency key TTL in seconds
# OPTIONAL — default: 86400 (24 hours)


# =============================================================================
# JWT — Auth Tokens
# =============================================================================

JWT_ACCESS_SECRET=
# Access token signing secret — minimum 64 characters
# REQUIRED — GENERATE WITH: openssl rand -base64 64
# NEVER reuse this value across environments

JWT_REFRESH_SECRET=
# Refresh token signing secret — must be DIFFERENT from JWT_ACCESS_SECRET
# REQUIRED — GENERATE WITH: openssl rand -base64 64 (run again separately)
# NEVER reuse this value across environments

JWT_ACCESS_EXPIRY=15m
# Access token TTL
# OPTIONAL — default: 15m
# FORMAT: 15m | 1h | 2d (ms-compatible string)

JWT_REFRESH_EXPIRY=30d
# Refresh token TTL
# OPTIONAL — default: 30d


# =============================================================================
# OTP — One-Time Password
# =============================================================================

OTP_EXPIRY_SECONDS=600
# OTP validity window in seconds
# OPTIONAL — default: 600 (overrides AppSettings if set here)

OTP_MAX_ATTEMPTS=3
# Maximum OTP verification attempts per phone per window
# OPTIONAL — default: 3

OTP_RATE_WINDOW_MINUTES=10
# Rate limit window for OTP send requests per phone number
# OPTIONAL — default: 10


# =============================================================================
# TOTP — Admin 2FA (Google Authenticator)
# =============================================================================

TOTP_ISSUER=Vipaasa Organics Admin
# Label shown inside Google Authenticator app
# REQUIRED

TOTP_ENCRYPTION_KEY=
# 32-byte key used to encrypt stored TOTP secrets in the database
# REQUIRED — GENERATE WITH: openssl rand -base64 32


# =============================================================================
# AWS — Common
# =============================================================================

AWS_REGION=ap-south-1
# AWS region — Mumbai for lowest latency to Indian users
# REQUIRED

AWS_ACCESS_KEY_ID=
# IAM user access key
# REQUIRED in development and staging
# PROD: Leave empty — EC2 IAM role provides credentials automatically

AWS_SECRET_ACCESS_KEY=
# IAM user secret key
# REQUIRED in development and staging
# PROD: Leave empty — EC2 IAM role provides credentials automatically


# =============================================================================
# AWS S3 — File Storage
# =============================================================================

S3_BUCKET_PRODUCTS=vipaasa-product-images
# S3 bucket name for product images (all 3 WebP sizes)
# REQUIRED
# Naming: vipaasa-product-images-staging / vipaasa-product-images-prod

S3_BUCKET_DOCUMENTS=vipaasa-documents
# S3 bucket name for quotation PDFs and invoices
# REQUIRED
# Naming: vipaasa-documents-staging / vipaasa-documents-prod

CLOUDFRONT_URL=https://d1xxxxxxxxxx.cloudfront.net
# CloudFront distribution base URL (no trailing slash)
# REQUIRED
# Get from: AWS CloudFront Console → Distributions → Domain name


# =============================================================================
# RAZORPAY — Payment Gateway
# =============================================================================

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# Razorpay API Key ID
# REQUIRED
# DEV/STAGING: rzp_test_* (test mode — no real money)
# PROD:        rzp_live_* (live mode — NEVER use test key in production)
# Get from: Razorpay Dashboard → Settings → API Keys

RAZORPAY_KEY_SECRET=
# Razorpay API Key Secret — NEVER expose this to frontend
# REQUIRED
# Get from: Razorpay Dashboard → Settings → API Keys

RAZORPAY_WEBHOOK_SECRET=
# Webhook secret for HMAC signature verification
# REQUIRED — set this BEFORE going live
# Get from: Razorpay Dashboard → Settings → Webhooks → Secret


# =============================================================================
# MSG91 — SMS & OTP (India — DLT Registered)
# =============================================================================

MSG91_AUTH_KEY=
# MSG91 authentication key
# REQUIRED
# Get from: MSG91 Dashboard → Username → Auth Key
# NOTE: DLT registration must be completed before any SMS can be sent in production

MSG91_SENDER_ID=VIPORG
# DLT registered sender ID (6 characters)
# REQUIRED — must be registered with TRAI DLT portal before use
# See: docs/DLT_CHECKLIST.md

MSG91_OTP_TEMPLATE_ID=
# DLT approved template ID for OTP messages
# REQUIRED — get after DLT template approval

MSG91_ORDER_TEMPLATE_ID=
# DLT approved template ID for order confirmation SMS
# REQUIRED — get after DLT template approval

MSG91_SHIPMENT_TEMPLATE_ID=
# DLT approved template ID for shipment update SMS
# REQUIRED — get after DLT template approval

MSG91_DELIVERY_TEMPLATE_ID=
# DLT approved template ID for delivery confirmation SMS
# REQUIRED — get after DLT template approval


# =============================================================================
# RESEND — Transactional Email
# =============================================================================

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Resend API key
# REQUIRED
# Get from: Resend Dashboard → API Keys

EMAIL_FROM=orders@vipaasaorganics.com
# Sender email address — must be a verified domain in Resend
# REQUIRED
# Verify domain at: Resend Dashboard → Domains

EMAIL_REPLY_TO=support@vipaasaorganics.com
# Reply-to address for all outgoing emails
# OPTIONAL


# =============================================================================
# FIREBASE — Push Notifications (FCM Admin SDK)
# =============================================================================

FIREBASE_PROJECT_ID=vipaasa-organics
# Firebase project ID
# REQUIRED
# Get from: Firebase Console → Project Settings → General

FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@vipaasa-organics.iam.gserviceaccount.com
# Service account client email
# REQUIRED
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key

FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Service account private key
# REQUIRED — keep the double quotes, the \n characters are literal
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# In config/firebase.ts: replace \\n with \n when parsing


# =============================================================================
# INTERAKT — WhatsApp Business API
# =============================================================================

INTERAKT_API_KEY=
# Interakt API key for WhatsApp Business API
# REQUIRED
# Get from: Interakt Dashboard → Settings → API & Webhook → API Key

INTERAKT_QUOTATION_TEMPLATE=quotation_send_v1
# Approved WhatsApp message template name for quotation sending
# REQUIRED — template must be approved by Meta before use
# Get from: Interakt Dashboard → Message Templates

WHATSAPP_SENDER_NUMBER=91XXXXXXXXXX
# WhatsApp Business number (without + prefix, with country code)
# REQUIRED


# =============================================================================
# SHIPROCKET — Shipping & PIN Code Serviceability
# =============================================================================

SHIPROCKET_EMAIL=
# Shiprocket account email
# REQUIRED
# Used to authenticate and obtain JWT token from Shiprocket API

SHIPROCKET_PASSWORD=
# Shiprocket account password
# REQUIRED

SHIPROCKET_CHANNEL_ID=
# Shiprocket channel ID for order creation
# OPTIONAL — get from Shiprocket Dashboard → Channels

SHIPROCKET_TOKEN_CACHE_TTL=86400
# Shiprocket JWT token cache duration in seconds
# OPTIONAL — default: 86400 (24 hours)
# Shiprocket tokens expire in 24h — cached in Redis to avoid re-auth on every request


# =============================================================================
# HCAPTCHA — Bot Protection on OTP Endpoint
# =============================================================================

HCAPTCHA_SECRET_KEY=
# hCaptcha secret key for server-side token verification
# REQUIRED
# Get from: hCaptcha Dashboard → Settings → Secret Key
# Pair with NEXT_PUBLIC_HCAPTCHA_SITE_KEY in web/.env


# =============================================================================
# SENTRY — Error Tracking
# =============================================================================

SENTRY_DSN=
# Sentry DSN for API error tracking
# OPTIONAL in development (leave blank to disable)
# REQUIRED in staging and production
# Get from: Sentry → Project → Settings → Client Keys (DSN)

SENTRY_ENVIRONMENT=development
# Sentry environment tag
# OPTIONAL — default: value of NODE_ENV
# OPTIONS: development | staging | production

SENTRY_TRACES_SAMPLE_RATE=0.1
# Percentage of transactions to trace (0.0 to 1.0)
# OPTIONAL — default: 0.1 (10%)
# Set lower in high-traffic production to control costs


# =============================================================================
# BETTERSTACK — Uptime Monitoring & Log Draining
# =============================================================================

BETTERSTACK_SOURCE_TOKEN=
# BetterStack log source token for Winston log draining
# OPTIONAL — logs still work without this (console output only)
# Get from: BetterStack → Logs → Sources → Create Source


# =============================================================================
# BUSINESS CONFIGURATION
# =============================================================================

SELLER_STATE=Andhra Pradesh
# Registered state of Vipaasa Organics
# REQUIRED — used to determine CGST/SGST (intra-state) vs IGST (inter-state) for GST invoices

SELLER_GSTIN=37XXXXXXXXXXXXX
# 15-digit GSTIN of Vipaasa Organics
# REQUIRED — printed on all tax invoices
# NOTE: AP state code is 37

SELLER_PAN=XXXXXXXXXXXXX
# PAN number of Vipaasa Organics
# REQUIRED — printed on invoices

COMPANY_NAME=Vipaasa Organics Pvt Ltd
# Legal company name — printed on invoices and quotations
# REQUIRED

COMPANY_ADDRESS=
# Full registered address — printed on invoices and quotations
# REQUIRED
# Example: "123 Organic Street, Vijayawada, Andhra Pradesh - 520001"

COMPANY_PHONE=+91XXXXXXXXXX
# Company phone — printed on invoices
# REQUIRED

SUPPORT_EMAIL=support@vipaasaorganics.com
# Customer support email — used in email footers and error responses
# REQUIRED

SUPPORT_PHONE=+91XXXXXXXXXX
# Customer support phone — used in email templates
# REQUIRED

FSSAI_LICENSE=XXXXXXXXXXXXXX
# FSSAI license number — printed on invoices for food products
# REQUIRED